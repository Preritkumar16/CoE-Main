generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum GrantCategory {
  GOVT_GRANT
  SCHOLARSHIP
  RESEARCH_FUND
  INDUSTRY_GRANT
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum ProblemMode {
  OPEN
  CLOSED
}

enum ProblemStatus {
  UNCLAIMED
  CLAIMED
  SOLVED
  ARCHIVED
}

enum ClaimStatus {
  IN_PROGRESS
  SUBMITTED
  SHORTLISTED
  ACCEPTED
  REVISION_REQUESTED
  REJECTED
}

enum EventStatus {
  UPCOMING
  ACTIVE
  JUDGING
  CLOSED
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  phone      String?
  password   String
  role       Role
  uid        String?
  isVerified Boolean    @default(false)
  status     UserStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  bookings          Booking[]
  newsPosts         NewsPost[]
  grants            Grant[]
  events            Event[]
  announcements     Announcement[]
  problemsCreated   ClaimMember[]
  hackathonsCreated HackathonEvent[] @relation("HackathonCreator")
  problemsAuthored  Problem[]        @relation("ProblemAuthor")

  @@map("users")
}

model Problem {
  id          Int             @id @default(autoincrement())
  title       String
  description String          @db.Text
  tags        String?
  mode        ProblemMode     @default(OPEN)
  status      ProblemStatus   @default(UNCLAIMED)
  createdById Int
  createdBy   User            @relation("ProblemAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  eventId     Int?
  event       HackathonEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  claims      Claim[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdById])
  @@index([eventId])
  @@index([status])
  @@index([mode])
  @@map("problems")
}

model Claim {
  id                Int           @id @default(autoincrement())
  problemId         Int
  problem           Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  teamName          String?
  members           ClaimMember[]
  status            ClaimStatus   @default(IN_PROGRESS)
  submissionUrl     String?
  submissionFileKey String?
  innovationScore   Int?
  technicalScore    Int?
  impactScore       Int?
  uxScore           Int?
  executionScore    Int?
  presentationScore Int?
  feasibilityScore  Int?
  finalScore        Int?
  score             Int?
  feedback          String?       @db.Text
  badges            String?
  isAbsent          Boolean       @default(false)
  reminderSent      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([problemId])
  @@index([status])
  @@index([updatedAt])
  @@map("claims")
}

model ClaimMember {
  id      Int    @id @default(autoincrement())
  claimId Int
  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    String @default("MEMBER")

  @@unique([claimId, userId])
  @@index([claimId])
  @@index([userId])
  @@map("claim_members")
}

model HackathonEvent {
  id          Int         @id @default(autoincrement())
  title       String
  description String?     @db.Text
  startTime   DateTime
  endTime     DateTime
  registrationOpen Boolean @default(true)
  status      EventStatus @default(UPCOMING)
  createdById Int
  createdBy   User        @relation("HackathonCreator", fields: [createdById], references: [id], onDelete: Cascade)
  problems    Problem[]
  pptFileKey  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([createdById])
  @@map("hackathon_events")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otps")
}

model Booking {
  id           Int           @id @default(autoincrement())
  studentId    Int
  student      User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  purpose      String        @db.Text
  date         DateTime
  timeSlot     String
  facilities   Json
  lab          String
  status       BookingStatus @default(PENDING)
  adminNote    String?       @db.Text
  reminderSent Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("bookings")
}

model NewsPost {
  id          Int      @id @default(autoincrement())
  title       String
  caption     String   @db.Text
  imageKey    String
  postedById  Int
  postedBy    User     @relation(fields: [postedById], references: [id], onDelete: Cascade)
  publishedAt DateTime @default(now())
  isVisible   Boolean  @default(true)

  @@map("news_posts")
}

model Grant {
  id            Int           @id @default(autoincrement())
  title         String
  issuingBody   String
  category      GrantCategory
  description   String        @db.Text
  deadline      DateTime
  referenceLink String?
  attachmentKey String?
  postedById    Int
  postedBy      User          @relation(fields: [postedById], references: [id], onDelete: Cascade)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@map("grants")
}

model Event {
  id               Int       @id @default(autoincrement())
  title            String
  description      String    @db.Text
  date             DateTime
  mode             EventMode
  registrationLink String?
  posterKey        String?
  postedById       Int
  postedBy         User      @relation(fields: [postedById], references: [id], onDelete: Cascade)
  isVisible        Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@map("events")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  text        String   @db.Text
  link        String?
  expiresAt   DateTime
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@map("announcements")
}

model HeroSlide {
  id        Int      @id @default(autoincrement())
  title     String
  caption   String   @db.Text
  imageKey  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_slides")
}
